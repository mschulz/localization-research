{"nodes": [{"id": "raw_infocom2000_radar_paper", "label": "RADAR: In-Building RF-Based User Location and Tracking System", "file_type": "paper", "source_file": "raw/infocom2000.pdf", "source_location": "Abstract", "source_url": null, "captured_at": null, "author": "Paramvir Bahl and Venkata N. Padmanabhan", "contributor": null}, {"id": "raw_infocom2000_nnss_algorithm", "label": "Nearest Neighbors in Signal Space (NNSS) Algorithm", "file_type": "concept", "source_file": "raw/infocom2000.pdf", "source_location": "Section 4", "source_url": null, "captured_at": null, "author": "Paramvir Bahl and Venkata N. Padmanabhan", "contributor": null, "rationale": "NNSS computes Euclidean distance in signal space between observed SS measurements and recorded reference SS values, picking the closest-matching location. It avoids the need for complex geometric triangulation by operating directly in signal space."}, {"id": "raw_infocom2000_waf_propagation_model", "label": "Wall Attenuation Factor (WAF) Propagation Model", "file_type": "concept", "source_file": "raw/infocom2000.pdf", "source_location": "Section 4.2", "source_url": null, "captured_at": null, "author": "Paramvir Bahl and Venkata N. Padmanabhan", "contributor": null, "rationale": "WAF was chosen over Rayleigh and Rician models as a compromise between simplicity and accuracy; it accounts for large-scale path loss and wall obstructions without requiring complex per-component isolation, and enables cost-effective deployment without dense empirical measurements."}, {"id": "raw_infocom2000_empirical_method", "label": "Empirical Signal Strength Method (Offline Phase Survey)", "file_type": "concept", "source_file": "raw/infocom2000.pdf", "source_location": "Section 4.1", "source_url": null, "captured_at": null, "author": "Paramvir Bahl and Venkata N. Padmanabhan", "contributor": null}, {"id": "raw_infocom2000_user_orientation_effect", "label": "User Body Orientation Effect on RSSI", "file_type": "concept", "source_file": "raw/in